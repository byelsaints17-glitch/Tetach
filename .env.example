# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# SMTP Settings (Optional, for sending real checkout emails to byelsaints17@gmail.com)
# If not configured, the app will automatically generate an Ethereal SMTP test inbox at checkout runtime.
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Mercado Pago API Settings (Optional)
# Enter your Mercado Pago Production or Sandbox Access Token (starts with APP_USR-)
# If not specified, a beautiful real-time payment simulator will guide the user through the payment process.
MERCADOPAGO_ACCESS_TOKEN=
# Enter your Mercado Pago Public Key (starts with APP_USR- or TEST-) for client-side integration
VITE_MERCADOPAGO_PUBLIC_KEY=

